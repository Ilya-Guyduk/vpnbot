# Токен бота от @BotFather
BOT_TOKEN=

# ID администраторов через запятую (узнать можно у @userinfobot)
ADMIN_IDS=123456789,987654321

# --- Ansible ---
# Путь до плейбука создания VPN-пользователя
ANSIBLE_PLAYBOOK_PATH=playbooks/create_vpn_user.yml
# Путь до inventory-файла
ANSIBLE_INVENTORY=inventory/hosts.ini
# Директория, куда Ansible сохраняет готовые конфиги (должна существовать на сервере)
VPN_CONFIG_OUTPUT_DIR=/tmp/vpn_configs
# Таймаут выполнения плейбука (секунды)
ANSIBLE_TIMEOUT=120
